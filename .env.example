# ─────────────────────────────────────────────────────────────
#  .env.example — copy this file to .env.local and fill values
#  NEVER commit .env or .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Database
# SQLite (local dev):   file:./prisma/prisma/dev.db
# PostgreSQL (prod):    postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL="file:./prisma/prisma/dev.db"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# Full URL of the app (required in production)
NEXTAUTH_URL="http://localhost:3000"

# Node environment: development | production | test
NODE_ENV="development"

# ── Optional: third-party services ────────────────────────────
# Add keys here as needed — never hardcode them in source files

# SMTP (for email notifications)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# Storage (e.g. Supabase Storage)
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
